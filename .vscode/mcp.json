{
	"servers": {
		"strategy-game": {
			"type": "stdio",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"StrategyGame/StrategyGame.McpServer/StrategyGame.McpServer.csproj",
				"--no-build",
				"-c",
				"Release"
			],
			"cwd": "${workspaceFolder}"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"oraios/serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"serena@latest",
				"--context",
				"ide-assistant"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		}
	},
	"inputs": []
}